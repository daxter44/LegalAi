@page "/czat"
@rendermode InteractiveServer
@using PrawoRAG.Llm.Grounding
@using PrawoRAG.Domain.Llm
@using PrawoRAG.Domain.Privacy
@using Microsoft.AspNetCore.Components.Authorization
@inject IChatService ChatService
@inject PrawoRAG.Domain.Embeddings.IEmbeddingProvider Embedder
@inject IConversationStore Store
@inject ICurrentUser CurrentUser
@inject RateGuard RateGuard
@inject CostGuard CostGuard
@inject AuthenticationStateProvider AuthState
@inject Microsoft.Extensions.Options.IOptions<DiagnosticsOptions> Diagnostics
@inject Microsoft.Extensions.Options.IOptions<DocumentsOptions> Documents
@implements IDisposable

<h1 class="sr-only">Czat z asystentem prawnym</h1>

<button class="btn-sidebar-toggle" @onclick="() => _mobileSidebarOpen = true" aria-label="Historia rozmów">
    ☰ Historia
</button>

<div class="chat-layout">
@if (_mobileSidebarOpen)
{
    <div class="sidebar-backdrop" @onclick="() => _mobileSidebarOpen = false"></div>
}
<aside class="chat-sidebar @(_mobileSidebarOpen ? "open" : "")">
    <button class="btn btn-new-chat" @onclick="NewConversation" disabled="@_busy">➕ Nowa rozmowa</button>
    <nav class="conv-list" aria-label="Historia rozmów">
        @foreach (var c in _conversations)
        {
            <button class="conv-item @(c.Id == _conversationId ? "active" : "")"
                    @onclick="() => LoadConversation(c.Id)" disabled="@_busy" title="@c.Title">
                <span class="conv-title">@c.Title</span>
                <span class="conv-date">@c.UpdatedAt.ToLocalTime().ToString("dd.MM HH:mm")</span>
            </button>
        }
    </nav>
</aside>

<div class="chat">
    <div class="chat-log">
        @if (_exchanges.Count == 0)
        {
            <div class="empty">
                <p class="empty-title">Zapytaj o przepis lub orzeczenie</p>
                <p class="empty-hint">Odpowiedzi powstają wyłącznie z cytowanych źródeł. To wstępny research — zawsze weryfikuj przy źródle.</p>
                <p class="empty-hint">Pierwszy raz? <a href="/o-systemie">Przeczytaj, co system umie, a czego nie</a>.</p>
            </div>
        }
        @foreach (var ex in _exchanges)
        {
            <div class="msg msg-user">@ex.Question</div>
            <div class="msg msg-assistant">
                @if (ex.Abstained)
                {
                    <div class="banner banner-warn" role="status">@ex.AbstainMessage</div>
                }
                else
                {
                    <div class="answer" aria-live="polite">
                        @if (ex.Answer.Length > 0)
                        {
                            @((MarkupString)MarkdownRenderer.ToSafeHtml(ex.Answer, ex.Sources.Count, ex.AnchorId, ex.DocFragments.Count))
                        }
                        else if (ex.Streaming)
                        {
                            <span class="typing" aria-label="generowanie odpowiedzi">…</span>
                        }
                    </div>

                    @if (ex.Done && !IsRefusal(ex))
                    {
                        <div class="verify-banner" role="note">
                            ⚖️ Wstępny research do weryfikacji — sprawdź w źródłach poniżej.
                            @if (ex.Check is { IsClean: false })
                            {
                                <span class="badge badge-danger" title="Model mógł przywołać coś spoza źródeł">⚠ cytaty do sprawdzenia</span>
                            }
                            else if (ex.Check is not null)
                            {
                                <span class="badge badge-ok" title="Cytaty zgodne z dostarczonymi źródłami">✓ cytaty zgodne</span>
                            }
                            @if (Diagnostics.Value.ShowTokenUsage && ex.Usage is { } u)
                            {
                                <span class="badge badge-tokens" title="Tokeny LLM: wejście (prompt ze źródłami i historią) / wyjście (odpowiedź)@(u.Estimated ? " — szacunek ze znaków, serwer nie raportuje usage" : "")">
                                    @(u.Estimated ? "~" : "")↓ @(u.InputTokens?.ToString("N0") ?? "?") · ↑ @(u.OutputTokens?.ToString("N0") ?? "?") tok
                                </span>
                            }
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(ex.Reasoning))
                    {
                        <details class="sources reasoning">
                            <summary>🧠 Rozumowanie modelu (@(ex.Reasoning.Length) zn.)</summary>
                            <div class="reasoning-body">@ex.Reasoning</div>
                            <p class="empty-hint">To wewnętrzny tok modelu — pomocniczy, NIE część odpowiedzi ani źródło. Rozstrzygają teza i cytowane źródła.</p>
                        </details>
                    }

                    @if (ex.DocFragments.Count > 0 && !IsRefusal(ex))
                    {
                        <details class="sources" open>
                            <summary>📄 Twój dokument: @ex.DocFileName (@ex.DocFragments.Count użyte fragmenty)</summary>
                            @foreach (var f in ex.DocFragments)
                            {
                                <div class="source-card" id="docsrc-@(ex.AnchorId)-@f.Index">
                                    <div class="source-head"><span class="source-n">[D@(f.Index)]</span></div>
                                    <blockquote class="source-snippet">@f.Snippet</blockquote>
                                </div>
                            }
                        </details>
                    }

                    @if (ex.Sources.Count > 0 && !IsRefusal(ex))
                    {
                        <details class="sources" open>
                            <summary>Źródła (@ex.Sources.Count)</summary>
                            @foreach (var s in ex.Sources)
                            {
                                <div class="source-card" id="src-@(ex.AnchorId)-@s.Index">
                                    <div class="source-head">
                                        <span class="source-n">[@s.Index]</span>
                                        <span class="source-label">@s.Label</span>
                                        @if (!string.IsNullOrWhiteSpace(s.AmendmentEffectiveDate))
                                        {
                                            <span class="badge badge-warn" title="Fragment nowelizacji jeszcze niewchłoniętej do tekstu jednolitego">🕓 nowelizacja — obowiązuje od @s.AmendmentEffectiveDate</span>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(s.Url))
                                        {
                                            <a class="source-link" href="@s.Url" target="_blank" rel="noopener noreferrer">oryginał ↗</a>
                                        }
                                    </div>
                                    <blockquote class="source-snippet">@s.Snippet</blockquote>
                                    @if (s.LegalBases is { Count: > 0 })
                                    {
                                        <details class="legal-bases-details">
                                            <summary>Podstawa prawna (@s.LegalBases.Count)</summary>
                                            <div class="legal-bases">
                                                @foreach (var b in s.LegalBases)
                                                {
                                                    <span class="legal-basis-chip">@b</span>
                                                }
                                            </div>
                                        </details>
                                    }
                                </div>
                            }
                        </details>
                    }
                }
                @if (ex.Error is not null)
                {
                    <div class="banner banner-danger" role="alert">Błąd: @ex.Error</div>
                }

                @if (ex.Done && ex.MessageId is not null)
                {
                    <div class="feedback">
                        @if (ex.FeedbackGiven is null)
                        {
                            <span class="feedback-label">Ocena:</span>
                            <button class="btn-ghost" @onclick='() => Feedback(ex, "up")' title="Trafna odpowiedź">👍</button>
                            <button class="btn-ghost" @onclick='() => Feedback(ex, "wrong-answer")'>zła odpowiedź</button>
                            <button class="btn-ghost" @onclick='() => Feedback(ex, "needless-refusal")'>niepotrzebna odmowa</button>
                        }
                        else
                        {
                            <span class="feedback-thanks">Dziękujemy za ocenę ✓</span>
                        }
                    </div>
                }
            </div>
        }
    </div>

    @if (_notice is not null)
    {
        <div class="banner banner-warn" role="status">@_notice</div>
    }
    @if (Documents.Value.Enabled)
    {
        <div class="chat-attach">
            <label class="attach-btn" title="Dołącz PDF (umowa, pismo, wyrok) — treść nie jest zapisywana">
                📎 <InputFile OnChange="OnFileSelected" accept=".pdf" disabled="@(_busy || _docLoading)" />
            </label>
            @if (_docLoading)
            {
                <span class="attach-chip">⏳ przetwarzam załącznik…</span>
            }
            else if (_document is not null)
            {
                <span class="attach-chip" title="Załącznik żyje do końca sesji — treść nie jest zapisywana">
                    📄 @_document.FileName (@_document.PageCount str.@(_document.Truncated ? $", obcięto do {PdfAttachmentExtractor.MaxPages}" : ""))
                    <button class="attach-remove" @onclick="RemoveDocument" disabled="@_busy" title="Usuń załącznik">✕</button>
                </span>
            }
            @if (_docNotice is not null)
            {
                <span class="attach-notice">@_docNotice</span>
            }
        </div>
    }
    @{ var _piiHits = SensitiveDataDetector.Detect(_input); }
    @if (_piiHits.Count > 0)
    {
        <div class="pii-warn" role="status">
            <span class="badge badge-warn"
                  title="System służy do researchu prawnego — opisz sprawę abstrakcyjnie, bez danych klienta. To podpowiedź, nie gwarancja.">
                ⚠️ możliwe dane osobowe: @string.Join(", ", _piiHits.Select(SensitiveDataDetector.Label))
            </span>
        </div>
    }
    <form class="chat-input" @onsubmit="Send" @onsubmit:preventDefault>
        <textarea @bind="_input" @bind:event="oninput" @onkeydown="OnKeyDown"
                  placeholder="Zadaj pytanie prawne… (Ctrl+Enter wysyła)" rows="2" disabled="@_busy"
                  aria-label="Pytanie"></textarea>
        <button type="submit" class="btn btn-primary" disabled="@(_busy || string.IsNullOrWhiteSpace(_input))">
            @(_busy ? "…" : "Wyślij")
        </button>
    </form>
</div>
</div>

@code {
    private const int MaxQuestionLen = 4000;
    private readonly List<Exchange> _exchanges = new();
    private List<ConversationSummary> _conversations = new();
    private string _input = "";
    private string? _notice;
    private bool _busy;
    private Guid? _conversationId;
    private CancellationTokenSource? _cts;
    private string _userId = "demo@local";

    // Załącznik (DOC-5): żyje wyłącznie w pamięci obwodu — F5/rekonekt = trzeba dołączyć ponownie
    // (decyzja #1 planu DOC: treść pism klientów nie jest persystowana).
    private DocumentContext? _document;
    private bool _docLoading;
    private string? _docNotice;

    protected override async Task OnInitializedAsync()
    {
        // Tożsamość z AuthenticationState (niezawodna w obwodzie Blazora), NIE z IHttpContextAccessor —
        // akcesor bywa null w interaktywnym renderowaniu (rekonekty, inne wątki) i cichy fallback na
        // wspólny placeholder MIESZAŁBY rozmowy i limity testerów. Rozwiązana RAZ na obwód.
        var auth = await AuthState.GetAuthenticationStateAsync();
        _userId = auth.User.Identity is { IsAuthenticated: true, Name: { Length: > 0 } name }
            ? name
            : CurrentUser.UserId; // bramka wyłączona (dev/M4) → placeholder jak dotąd
        await RefreshConversationsAsync();

        // AUTO-WZNOWIENIE ostatniej rozmowy. _conversationId żyje w pamięci obwodu — odświeżenie strony,
        // rekonekt SignalR albo wejście na /o-systemie i powrót NISZCZĄ komponent; bez wznowienia każde
        // kolejne pytanie zakładało NOWĄ rozmowę (sidebar puchł wpisem per pytanie). „Nowa rozmowa"
        // jawnie zaczyna od zera.
        if (_conversations.Count > 0) await LoadConversation(_conversations[0].Id);
    }

    /// <summary>Lista rozmów w sidebarze — best-effort (brak bazy nie blokuje czatu).</summary>
    private async Task RefreshConversationsAsync()
    {
        try { _conversations = (await Store.ListConversationsAsync(_userId, 50, CancellationToken.None)).ToList(); }
        catch { /* best-effort */ }
    }

    /// <summary>Panel historii na mobile (≤900px, patrz app.css) — na desktopie sidebar jest zawsze
    /// widoczny, ta flaga tam nic nie zmienia (CSS gatuje `.open` tylko pod media query).</summary>
    private bool _mobileSidebarOpen;

    private void NewConversation()
    {
        if (_busy) return;
        _exchanges.Clear();
        _conversationId = null;
        _notice = null;
        _input = "";
        _mobileSidebarOpen = false;
    }

    /// <summary>Wczytuje rozmowę z historii: pary user/assistant → Exchange. Follow-upy działają
    /// od razu (Send buduje historię z _exchanges). Store filtruje po UserId — cudza rozmowa = pusto.</summary>
    private async Task LoadConversation(Guid id)
    {
        if (_busy || id == _conversationId) return;
        List<StoredMessage> messages;
        try { messages = (await Store.GetMessagesAsync(id, _userId, CancellationToken.None)).ToList(); }
        catch { _notice = "Nie udało się wczytać rozmowy."; return; }
        if (messages.Count == 0) return; // nie istnieje albo nie moja

        _exchanges.Clear();
        _conversationId = id;
        _notice = null;
        _mobileSidebarOpen = false;
        Exchange? current = null;
        foreach (var m in messages)
        {
            if (m.Role == "user")
            {
                current = new Exchange { Question = m.Content, Done = true };
                _exchanges.Add(current);
            }
            else if (current is not null)
            {
                if (m.Abstained) { current.Abstained = true; current.AbstainMessage = m.Content; }
                else current.Answer = m.Content;
                current.Sources = m.Sources;
                current.MessageId = m.Id;
                current.Model = m.Model;
                // CitationCheck z historii: znamy tylko werdykt (bool) — odtwarzamy minimalny obiekt,
                // żeby badge ✓/⚠ renderował się jak przy świeżej odpowiedzi (UI czyta tylko IsClean).
                current.Check = m.CitationClean switch
                {
                    true => new CitationCheck([], [], []),
                    false => new CitationCheck([], [], ["(wynik z historii)"]),
                    null => null,
                };
                current = null;
            }
        }
    }

    /// <summary>LLM odmówił NA POZIOMIE TREŚCI (ocenił dostarczone źródła jako nietrafne) — bramka
    /// retrievalu (<c>ex.Abstained</c>) tego nie łapie, bo próg podobieństwa i tak przepuścił. Bez tego
    /// panel „Źródła" pokazywał nietrafione fragmenty obok odpowiedzi „Nie mam wystarczających źródeł" —
    /// mylące (zgłoszone przy pytaniu spoza domeny, gdzie retrieval znalazł tylko przypadkowo podobne
    /// fragmenty prawnicze). Sprawdzane dopiero gdy tura się skończy (Done) — nie przy każdym tokenie.</summary>
    private static bool IsRefusal(Exchange ex) =>
        ex.Done && !ex.Abstained && ex.Answer.Contains(GroundedPrompt.RefusalMarker, StringComparison.OrdinalIgnoreCase);

    /// <summary>Kotwice źródeł tury (etykieta lokalizatora + tytuł aktu, np. „art. 157 § 1 KW",
    /// „Kodeks wykroczeń") dla kontekstualizacji retrievalu follow-upu — czyste, bez ryzyka halucynacji.
    /// Garść pierwszych źródeł wystarcza; więcej rozmywa embedding bieżącej intencji.</summary>
    private const int FollowUpSourceAnchorsTaken = 4;
    private static IReadOnlyList<string> SourceAnchors(Exchange ex) =>
        ex.Sources
            .Take(FollowUpSourceAnchorsTaken)
            .Select(s => $"{s.Label} {s.Title}".Trim())
            .Where(s => !string.IsNullOrWhiteSpace(s))
            .ToList();

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && e.CtrlKey) await Send();
    }

    private void RemoveDocument()
    {
        _document = null;
        _docNotice = null;
    }

    /// <summary>Upload PDF → ekstrakcja (PdfPig) → bramka skanów → chunki+embeddingi w pamięci.
    /// Każdy błąd = czytelny komunikat, nigdy 500 (uszkodzony/zaszyfrowany plik to normalny przypadek).</summary>
    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        _docNotice = null;
        _document = null;
        var file = e.File;
        if (!file.Name.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase))
        {
            _docNotice = "Obsługujemy wyłącznie pliki PDF.";
            return;
        }
        if (file.Size > PdfAttachmentExtractor.MaxBytes)
        {
            _docNotice = $"Plik jest za duży (limit {PdfAttachmentExtractor.MaxBytes / (1024 * 1024)} MB).";
            return;
        }

        _docLoading = true;
        try
        {
            using var ms = new MemoryStream();
            await file.OpenReadStream(PdfAttachmentExtractor.MaxBytes).CopyToAsync(ms);
            var pdf = PdfAttachmentExtractor.Extract(ms.ToArray());
            if (pdf.IsScanLike)
            {
                _docNotice = "Ten PDF wygląda na skan — obsługujemy dokumenty z warstwą tekstową (bez OCR).";
                return;
            }
            _document = await DocumentContext.CreateAsync(file.Name, pdf, Embedder, CancellationToken.None);
        }
        catch (Exception)
        {
            _docNotice = "Nie udało się odczytać tego PDF (plik uszkodzony lub zabezpieczony).";
        }
        finally
        {
            _docLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task Send()
    {
        var question = _input.Trim();
        if (question.Length == 0 || _busy) return;

        _notice = null;
        if (question.Length > MaxQuestionLen)
        {
            _notice = $"Pytanie jest za długie (limit {MaxQuestionLen} znaków).";
            return;
        }
        if (!RateGuard.TryAcquire(_userId))
        {
            _notice = "Za dużo zapytań w krótkim czasie — spróbuj ponownie za chwilę.";
            return;
        }
        // Twardy dzienny cap kosztów LLM (3.7) — obok okna minutowego RateGuard.
        if (!CostGuard.TryAcquire(_userId, out var limitReason))
        {
            _notice = CostGuard.LimitMessage(limitReason);
            return;
        }

        _input = "";
        _busy = true;

        // Kontekst follow-upów: poprzednie ZAKOŃCZONE tury (bez błędów) — pytanie + odpowiedź
        // (null przy abstynencji bramki LUB odmowie LLM w tekście — IsRefusal). Bez tego odmówiona
        // tura (np. pytanie spoza domeny, na które LLM odpowiedział "Nie mam źródeł" mimo że bramka
        // retrievalu nie zareagowała) liczyła się jako pełnoprawny temat do kontynuowania — kolejne,
        // NIEZWIĄZANE pytanie sklejało się z nią jako "dopytanie" i retrieval szukał złego tematu.
        // Limit tur egzekwuje GroundedPrompt/FollowUpQuery.
        var history = _exchanges
            .Where(e => e.Done && e.Error is null)
            .Select(e => e.Abstained || IsRefusal(e)
                ? new ChatTurn(e.Question, null)
                : new ChatTurn(e.Question, e.Answer, SourceAnchors(e)))
            .ToList();

        var ex = new Exchange { Question = question, Streaming = true };
        _exchanges.Add(ex);
        _cts = new CancellationTokenSource();
        var ct = _cts.Token;

        // Persystencja jest best-effort — awaria zapisu NIE blokuje odpowiedzi.
        _conversationId ??= await Try(() => Store.CreateConversationAsync(_userId, question, ct));
        if (_conversationId is { } cid) await Try(() => Store.AddUserMessageAsync(cid, question, ct));

        try
        {
            await foreach (var evt in ChatService.AskAsync(question, history, _document, ct))
            {
                switch (evt)
                {
                    case SourcesEvent s: ex.Sources = s.Sources; break;
                    case DocSourcesEvent d: ex.DocFileName = d.FileName; ex.DocFragments = d.Fragments; break;
                    case TokenEvent t: ex.Answer += t.Text; break;
                    case ReasoningEvent r: ex.Reasoning = r.Text; break;
                    case AbstainEvent a: ex.Abstained = true; ex.AbstainMessage = a.Message; break;
                    case DoneEvent d: ex.Done = true; ex.Check = d.Check; ex.Model = d.Model; ex.Usage = d.Usage; break;
                    case ChatErrorEvent err: ex.Error = err.Message; break;
                }
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) { /* przerwane przez użytkownika */ }
        catch (Exception e) { ex.Error = e.Message; }
        finally
        {
            ex.Streaming = false;
            CostGuard.Record(_userId, ex.Answer.Length); // dolicz wyjście do dziennego budżetu
            if (_conversationId is { } cid2)
            {
                var content = ex.Abstained ? (ex.AbstainMessage ?? "") : ex.Answer;
                ex.MessageId = await Try(() => Store.AddAssistantMessageAsync(
                    cid2, content, ex.Sources, ex.Abstained, ex.Check?.IsClean, ex.Model, CancellationToken.None));
            }
            _busy = false;
            await RefreshConversationsAsync(); // nowa rozmowa/tytuł pojawia się w sidebarze
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task Feedback(Exchange ex, string verdict)
    {
        if (ex.MessageId is not { } mid || ex.FeedbackGiven is not null) return;
        try
        {
            await Store.AddFeedbackAsync(mid, _userId, verdict, null, CancellationToken.None);
            ex.FeedbackGiven = verdict;
        }
        catch { /* feedback best-effort */ }
        await InvokeAsync(StateHasChanged);
    }

    private static async Task<Guid?> Try(Func<Task<Guid>> op)
    {
        try { return await op(); } catch { return null; }
    }

    private static async Task Try(Func<Task> op)
    {
        try { await op(); } catch { /* best-effort */ }
    }

    public void Dispose() => _cts?.Cancel();

    private sealed class Exchange
    {
        /// <summary>Unikalny prefiks kotwic cytowań tej wymiany — [n] w odpowiedzi linkuje do
        /// #src-{AnchorId}-{n}; bez prefiksu kotwice różnych wymian w jednym logu by się zderzały.</summary>
        public string AnchorId { get; } = Guid.NewGuid().ToString("N")[..8];

        public required string Question { get; init; }
        public string Answer { get; set; } = "";

        /// <summary>„Rozumowanie" modelu (thinking) wydzielone ze strumienia — tylko in-memory (nie
        /// persystowane; rozmowa z historii go nie ma). Puste = model nie „myślał".</summary>
        public string Reasoning { get; set; } = "";
        public IReadOnlyList<ChatSource> Sources { get; set; } = [];

        /// <summary>Fragmenty załącznika użyte w tej turze (przestrzeń [Dk]); tylko in-memory —
        /// rozmowa wczytana z historii ich nie ma ([Dk] renderują się wtedy jako zwykły tekst).</summary>
        public IReadOnlyList<DocSource> DocFragments { get; set; } = [];
        public string? DocFileName { get; set; }
        public bool Abstained { get; set; }
        public string? AbstainMessage { get; set; }
        public CitationCheck? Check { get; set; }
        public string? Model { get; set; }
        public bool Streaming { get; set; }
        public bool Done { get; set; }
        public string? Error { get; set; }
        public Guid? MessageId { get; set; }
        public string? FeedbackGiven { get; set; }
        public LlmUsage? Usage { get; set; }
    }
}
