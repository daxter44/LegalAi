@inherits LayoutComponentBase
@inject Microsoft.Extensions.Options.IOptions<PrawoRAG.Api.Services.AnalysisOptions> Analysis

<div class="app-shell">
    <header class="app-header">
        <a class="app-brand" href="/" title="Strona główna">
            <span class="app-logo">§</span>
            <span class="app-title">PrawoRAG</span>
            <span class="app-tag">demo</span>
        </a>
        <nav class="app-nav">
            <a href="/szukaj">Wyszukiwarka</a>
            @if (Analysis.Value.Enabled)
            {
                <a href="/analiza">Analiza dokumentów</a>
            }
            <a href="/o-systemie">O systemie</a>
        </nav>
    </header>
    <main class="app-main">
        @Body
    </main>
</div>
